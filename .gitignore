# This file is for zig-specific build artifacts.
# If you have OS-specific or editor-specific files to ignore,
# such as *.swp or .DS_Store, put those in your global
# ~/.gitignore and put this in your ~/.gitconfig:
#
# [core]
#     excludesfile = ~/.gitignore
#
# Cheers!
# -andrewrk

zig-cache/
.zig-cache/
zig-out/
*.o
/release/
/debug/
/build/
/build-*/
/docgen_tmp/

# Local package/cache artifacts.
/zig-pkg/

# Ad hoc root-level test binaries/scratch files.
/test_mach
/test_mach2
/test_nano
/test_timer
/test_timer2
/test_timer3
/test_timer4

data/*
!data/.gitkeep
